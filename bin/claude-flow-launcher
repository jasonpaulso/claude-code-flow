#!/usr/bin/env node

const { execSync } = require("child_process");
const path = require("path");
const fs = require("fs");

// Get the installation directory
const scriptPath = __dirname;
const projectRoot = path.dirname(scriptPath);
const mainFile = path.join(projectRoot, "src", "cli", "index.ts");

// Check if main file exists
if (!fs.existsSync(mainFile)) {
  console.error("Error: Claude-Flow source files not found.");
  console.error(`Expected file at: ${mainFile}`);
  process.exit(1);
}

// Pass through all arguments to deno
const args = process.argv.slice(2);
const denoCmd = `deno run --allow-all ${mainFile} ${args.map((arg) => `"${arg}"`).join(" ")}`;

try {
  execSync(denoCmd, { stdio: "inherit" });
} catch (error) {
  // Exit with the same code as the deno process
  process.exit(error.status || 1);
}
