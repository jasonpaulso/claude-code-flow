# Claude-Flow Ubuntu-based Docker Image
FROM ubuntu:22.04

# Prevent interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    unzip \
    git \
    nodejs \
    npm \
    bash \
    && rm -rf /var/lib/apt/lists/*

# Install Deno
RUN curl -fsSL https://deno.land/x/install/install.sh | sh
ENV DENO_INSTALL="/root/.deno"
ENV PATH="$DENO_INSTALL/bin:$PATH"

# Set working directory
WORKDIR /opt/claude-flow

# Copy source code
COPY . .

# Use the docker-specific launcher
RUN cp bin/claude-flow-launcher-docker bin/claude-flow-launcher || true

# Make scripts executable
RUN chmod +x bin/claude-flow-launcher

# Create symlink for global usage
RUN ln -s /opt/claude-flow/bin/claude-flow-launcher /usr/local/bin/claude-flow

# Create workspace directory
RUN mkdir -p /workspace

# Set environment variables
ENV CLAUDE_FLOW_DOCKER=true
ENV PATH="/opt/claude-flow/bin:${PATH}"

# Default working directory
WORKDIR /workspace

# Entry point
ENTRYPOINT ["claude-flow"]

# Default command
CMD ["--help"]